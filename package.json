{
  "name": "bliss-contents-hero",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "vinext build && node scripts/prepare-deploy.mjs",
    "start": "next start",
    "lint": "next lint",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "wrangler dev --config dist/server/wrangler.json",
    "deploy:vinext": "vinext-cloudflare deploy --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@vinext/cloudflare": "^1.0.0-beta.3",
    "gsap": "^3.12.7",
    "lenis": "^1.3.1",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-server-dom-webpack": "^19.2.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.46.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitejs/plugin-rsc": "^0.5.30",
    "typescript": "^5.8.2",
    "vinext": "^1.0.0-beta.3",
    "vite": "^8.1.5",
    "wrangler": "^4.113.0"
  },
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  },
  "type": "module"
}
